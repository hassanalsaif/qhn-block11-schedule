rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Schedule and Daytime Coverage overrides: anyone can read (matches the
    // app's current fully-public behavior), only signed-in admins can write.
    // Real enforcement lives here, not in the client's isAdmin UI flag.
    match /schedules/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /manualUnavail/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /consultantSchedules/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // Resident database: one document per resident (doc ID = short name).
    match /residents/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // WhatsApp bot bookkeeping. Both collections are touched ONLY by the bot's
    // Cloud Function, which uses the Admin SDK and bypasses these rules. The
    // rules exist to lock out every OTHER client:
    //   callAudit    -- append-only edit log (contains actor + change details);
    //                   no browser client may read or forge entries.
    //   pendingEdits -- transient "awaiting confirmation" state, keyed by the
    //                   proposing chief's short name; bot-internal only.
    match /callAudit/{docId} {
      allow read, write: if false;
    }
    match /pendingEdits/{docId} {
      allow read, write: if false;
    }
  }
}
