# Copy to bot/.env (already gitignored) for local testing against the
# Firebase emulator suite. In production these are set one-time via
# `firebase functions:secrets:set <NAME>` (Google Secret Manager), NOT this
# file -- see the defineSecret() calls in index.js.

# Anthropic API key (Claude) -- console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Meta WhatsApp Cloud API -- from the Meta App dashboard
WHATSAPP_TOKEN=...            # permanent System User access token (not the 24h test token)
WHATSAPP_PHONE_NUMBER_ID=...  # WhatsApp > API Setup
WHATSAPP_VERIFY_TOKEN=...     # any string you choose; must match what you register for the webhook
WHATSAPP_APP_SECRET=...       # App dashboard > Settings > Basic > App Secret (verifies X-Hub-Signature-256)
